PORT=4000
CLIENT_ORIGIN=http://localhost:5173

JWT_ACCESS_SECRET=change-me-min-16-chars
JWT_ACCESS_EXPIRES_IN=7d

SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Wajib salah satu (urutan prioritas):
# 1. Secret / service role (disarankan untuk production)
SUPABASE_SERVICE_ROLE_KEY=
# 2. Alias secret key
SUPABASE_SECRET_KEY=
# 3. Publishable key (cukup untuk demo setelah jalankan supabase/setup.sql)
SUPABASE_PUBLISHABLE_KEY=

SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_PRODUCT_BUCKET=products
